SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001

# Render PostgreSQL (auto-set by Render when linked)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Cloudinary — image storage (get from https://console.cloudinary.com)
# Option A: single URL
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Option B: separate vars
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email OTP (2FA on login)
# Local dev: codes print to the terminal (console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Production SMTP example (Gmail, SendGrid, Resend, etc.)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=TaskFlow <noreply@yourdomain.com>
